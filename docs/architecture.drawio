        <!-- 问题说明框 -->
        <mxCell id="200" value="&#10060; 核心问题：&#xa;1. 单个类承担 7 大类职责，610 行代码难以维护&#xa;2. 输入处理、UI 管理、战斗逻辑高度耦合&#xa;3. 无法扩展新回合模式（如交替行动）&#xa;4. 修改任何功能都有牵一发动全身的风险" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=12;fontColor=#b85450;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="350" y="230" width="700" height="100" as="geometry" />
        </mxCell>

