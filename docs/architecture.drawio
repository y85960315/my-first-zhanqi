  <!-- ================================================================
       Page 2: 目标架构设计 — 5 层全宽垂直分层
       ================================================================ -->
  <diagram name="目标架构设计" id="p2">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1250">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="2" value="目标架构 — 5 层分层设计 (全宽垂直布局)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="800" height="40" as="geometry" />
        </mxCell>

        <!-- ===== L1: GameManager (y=70, h=150) ===== -->
        <mxCell id="l1" value="第 1 层 — 游戏管理器 (GameManager)   |   编排者：持有下层引用，不处理具体逻辑" style="swimlane;swimlaneLine=0;startSize=36;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="1300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="l1a" value="游戏初始化&#xa;(地图 + 角色 + 系统)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f4ff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="l1">
          <mxGeometry x="20" y="50" width="180" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l1b" value="游戏流程控制&#xa;开始 → 回合循环 → 胜负判定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f4ff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="l1">
          <mxGeometry x="240" y="50" width="220" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l1d" value="持有引用:  TurnManager  |  UIManager  |  players[] / enemies[]  |  BattleGridData  |  CombatSystem" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eeff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="l1">
          <mxGeometry x="500" y="50" width="760" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l1e" value="职责：仅编排游戏生命周期 — 初始化 → 开始回合 → 检测胜负 → 循环" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#6c8ebf;fontStyle=2;" vertex="1" parent="l1">
          <mxGeometry x="500" y="100" width="760" height="30" as="geometry" />
        </mxCell>

        <!-- e12: L1 → L2 -->
        <mxCell id="e12" value="委托回合控制" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#6c8ebf;strokeWidth=2;fontColor=#666666;fontSize=10;" edge="1" parent="1" source="l1" target="l2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== L2: TurnManager (y=260, h=190) ===== -->
        <mxCell id="l2" value="第 2 层 — 回合管理器 (TurnManager)   |   核心新增模块：控制回合流转 + 行动者调度" style="swimlane;swimlaneLine=0;startSize=36;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="260" width="1300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="l2a" value="回合开始/结束&#xa;玩家阶段 → 敌人阶段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;fontSize=11;" vertex="1" parent="l2">
          <mxGeometry x="20" y="50" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l2b" value="行动者队列管理&#xa;遍历 pending_players&#xa;切换当前行动角色" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;fontSize=11;" vertex="1" parent="l2">
          <mxGeometry x="250" y="50" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l2c" value="回合模式 (可扩展策略)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="l2">
          <mxGeometry x="480" y="50" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l2d" value="TeamMode&#xa;所有玩家 → 所有敌人" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="l2">
          <mxGeometry x="660" y="40" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="l2e" value="AlternateMode&#xa;玩家1→敌人1→玩家2…" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="l2">
          <mxGeometry x="840" y="40" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="l2f" value="信号: player_action_started / finished&#xa;        player_phase_ended / enemy_phase_ended&#xa;        round_ended" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#82b366;spacingLeft=5;spacingTop=3;" vertex="1" parent="l2">
          <mxGeometry x="660" y="105" width="500" height="50" as="geometry" />
        </mxCell>

        <!-- e23: L2 → L3 -->
        <mxCell id="e23" value="控制行动者" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#82b366;strokeWidth=2;fontColor=#666666;fontSize=10;" edge="1" parent="1" source="l2" target="l3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== L3: Controllers (y=490, h=165) ===== -->
        <mxCell id="l3" value="第 3 层 — 控制器层 (Controllers)   |   PlayerController: 鼠标输入  |  AIController: 自动决策" style="swimlane;swimlaneLine=0;startSize=36;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="490" width="1300" height="165" as="geometry" />
        </mxCell>
        <mxCell id="l3a" value="Controller (基类)&#xa;do_action()  — 唯一对外接口&#xa;子类自行实现决策逻辑" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="l3">
          <mxGeometry x="20" y="50" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="l3b" value="PlayerController&#xa;do_action() → 激活输入监听&#xa;监听鼠标/键盘&#xa;Phase: IDLE→MOVE→ATTACK&#xa;通过信号通知动作完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="l3">
          <mxGeometry x="250" y="50" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="l3c" value="AIController&#xa;do_action() → 内部完成全部决策&#xa;自动选择移动位置/攻击目标&#xa;优先级策略：低血量优先" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="l3">
          <mxGeometry x="500" y="50" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="l3d" value="&#9888; TurnManager 只管调用 do_action()&#xa;不关心内部是玩家输入还是 AI 决策" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e5f5;rounded=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=2;" vertex="1" parent="l3">
          <mxGeometry x="790" y="55" width="300" height="50" as="geometry" />
        </mxCell>

        <!-- e35: L3 → L5 (控制器只读查询数据层) -->
        <mxCell id="e35" value="只读查询" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;strokeWidth=1;dashed=1;fontColor=#666666;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="l3" target="l5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1370" y="572" />
              <mxPoint x="1370" y="1080" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== L4: UIManager (y=695, h=170) ===== -->
        <mxCell id="l4" value="第 4 层 — UI 管理器 (UIManager)   |   从 GameManager 拆分：统一管理所有 UI 组件" style="swimlane;swimlaneLine=0;startSize=36;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1">
